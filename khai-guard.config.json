{
  "source": ["cultures/**"],
  "test": ["tests/**", ".github/workflows/**", ".husky/**"],
  "exemptRenames": true,
  "licensePolicy": {
    "packages": ["package.json"],
    "packageLicenses": ["SEE LICENSE IN LICENSE and LICENSE-CODE"]
  },
  "branchScope": {
    "shared": [
      ".changeset/**",
      "package.json",
      "package-lock.json",
      "CHANGELOG.md",
      ".prettierrc",
      ".gitignore",
      ".npmrc",
      ".nvmrc",
      "LICENSE",
      "LICENSE-CODE",
      "SECURITY.md",
      "registry.json"
    ],
    "lanes": [
      {
        "pattern": "culture/*",
        "layer": "solution",
        "allow": ["cultures/**"]
      },
      {
        "pattern": "group/*",
        "layer": "solution",
        "allow": ["groups/**"]
      },
      {
        "pattern": "governance/*",
        "layer": "governance",
        "allow": [
          ".github/**",
          ".husky/**",
          "khai-guard.config.json",
          "tests/**",
          "README.md",
          "GEMINI.md",
          "CLAUDE.md",
          "REFERENCE.md",
          "REFERENCES.md",
          "management/**"
        ]
      },
      {
        "pattern": "changeset-release/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "dependabot/*",
        "layer": "general",
        "allow": ["**/package.json", "**/package-lock.json", ".github/workflows/**"]
      },
      {
        "pattern": "chore/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "fix/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "docs/*",
        "layer": "general",
        "allow": []
      }
    ],
    "riders": [
      {
        "pattern": "management/orders/**",
        "fallback": "governance"
      }
    ]
  },
  "changesetPolicy": {
    "countDrivenAdd": ["cultures/*/play_*.md"]
  }
}
